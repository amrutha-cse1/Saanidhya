# Copy this file to ../.env (project root) or to murf-backend/.env
# IMPORTANT: Keep your MURF_API_KEY secret. Do NOT commit it to source control.

# Murf API key (server-side only)
MURF_API_KEY=

# Optional default Murf voice id (example: en-IN-arohi)
MURF_VOICE_ID=en-IN-arohi

# Twilio credentials (optional - for real calls/SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=

# OpenAI API key (optional - for chat / Whisper)
OPENAI_API_KEY=

# Server port
PORT=5000
